# === Core ===
APP_NAME=Gnosis
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# === Database ===
DATABASE_URL=postgresql+asyncpg://gnosis:gnosis_secret@localhost:5432/gnosis

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Auth (REQUIRED — app refuses to start without a real key in non-debug mode) ===
# Generate with: openssl rand -hex 32
SECRET_KEY=
# Optional separate keys; leave blank to use SECRET_KEY-backed defaults where supported.
JWT_SECRET_KEY=
ENCRYPTION_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# === CORS (comma-separated) ===
ALLOWED_ORIGINS=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# === LLM Providers ===
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=100

# === Outbound Auto-API allowlist (comma-separated hostnames) ===
# Required in production if you enable /api/v1/auto-api connection calls.
GNOSIS_AUTO_API_ALLOWED_HOSTS=

# === SSO (Optional) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === AWS (leave empty for local dev, auto-detected on ECS via IAM roles) ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOAD_BUCKET=
S3_EXPORT_BUCKET=
SQS_EXECUTION_QUEUE_URL=
SQS_WEBHOOK_QUEUE_URL=
SES_SENDER_EMAIL=
DYNAMODB_EXECUTION_TABLE=
DYNAMODB_SESSIONS_TABLE=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# === Performance ===
CACHE_TTL_SECONDS=300
MAX_CACHE_SIZE=1000

# === Optional: Monitoring ===
SENTRY_DSN=
PROMETHEUS_ENABLED=true
