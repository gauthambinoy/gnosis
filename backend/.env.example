# Gnosis Backend Configuration
APP_NAME=Gnosis
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://gnosis:your_password@localhost:5432/gnosis

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (CHANGE THIS! Generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-64-char-string

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# LLM Provider
DEFAULT_LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# SSO (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AWS (leave empty for local development, auto-detected on ECS via IAM roles)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOAD_BUCKET=
S3_EXPORT_BUCKET=
SQS_EXECUTION_QUEUE_URL=
SQS_WEBHOOK_QUEUE_URL=
SES_SENDER_EMAIL=
DYNAMODB_EXECUTION_TABLE=
DYNAMODB_SESSIONS_TABLE=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Sentry (Optional)
SENTRY_DSN=
